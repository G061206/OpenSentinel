APP_NAME=OpenSentinel
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=postgresql+psycopg://opensentinel:opensentinel@postgres:5432/opensentinel
REDIS_URL=redis://redis:6379/0

DEFAULT_FETCH_TIMEOUT_SECONDS=20
DEFAULT_RETRY_TIMES=3
DEFAULT_RATE_LIMIT_PER_SOURCE=5

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
BEAT_SCAN_INTERVAL_MINUTES=15

LLM_PROVIDER=mock
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=25

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_URL=https://example.com

BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_API_KEY=
BAILIAN_MODEL=qwen-plus

WECOM_WEBHOOK_URL=
WECOM_MESSAGE_FORMAT=text
